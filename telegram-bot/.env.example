# انسخ هذا الملف إلى .env ثم ضع التوكن الحقيقي
# (استعمل: copy .env.example .env    ولا فقط أنشئ .env جديدًا)
# احصل على التوكن من @BotFather على تيليگرام

BOT_TOKEN=ضع_توكن_البوت_هنا

# (اختياري) مستوى السجلّات: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# ===== التذكير التلقائي بأذكار الصباح والمساء =====
# المنطقة الزمنية (مثال: Africa/Casablanca ، Asia/Riyadh ، Europe/Paris)
REMINDER_TIMEZONE=Africa/Casablanca
# وقت تذكير أذكار الصباح (24 ساعة، صيغة HH:MM)
MORNING_TIME=06:30
# وقت تذكير أذكار المساء
EVENING_TIME=17:30
